{
  "buildCommand": "vite build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/server.js": {
      "includeFiles": "dist/server/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!_build/|assets/|favicon.ico|robots.txt|manifest.json).*)", "destination": "/api/server" }
  ]
}
